# Groq API Key para análisis de texto con IA
# Obtén tu key gratis en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_key_aqui

# IMPORTANTE: 
# 1. Copia este archivo como .env
# 2. Reemplaza "gsk_tu_key_aqui" con tu key real
# 3. NUNCA subas el archivo .env a GitHub
# 4. Para producción, usa variables de entorno del servidor (Vercel, Netlify, etc.)
